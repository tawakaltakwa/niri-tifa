{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "modules": [
    "title",
    "separator",
    "os",
    {
      "type": "command",
      "key": "OS Age",
      "text": "birth=$(stat -c %W /); current=$(date +%s); echo $(( (current - birth) / 86400 )) days"
    },
    "host",
    "kernel",
    "packages",
    "shell",
    "de",
    "wm",
    "terminal",
    "localip",
    "break",
    "colors"
  ]
}